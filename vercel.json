{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/cron/transaction-expiry.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/transaction-expiry",
      "schedule": "* * * * *"
    }
  ]
}
