generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  birthdate    DateTime
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  avatar       String?
  fullName     String
  referral     Int?
  coupons      Coupon[]
  events       Event[]       @relation("OrganizerEvents")
  points       Point[]
  reviews      Review[]      @relation("Reviewer")
  transactions Transaction[]
  voucherOwner Voucher[]     @relation("Organizer")
  vouchers     Voucher[]     @relation("User")
  refreshToken RefreshToken?

  @@map("users")
}

model Event {
  id          Int          @id @default(autoincrement())
  name        String
  artist      String
  location    String
  city        String?
  startDate   DateTime
  endDate     DateTime
  thumbnail   String?
  totalTicket Int
  category    String
  description String?
  deletedAt   DateTime?
  organizerId Int
  organizer   User         @relation("OrganizerEvents", fields: [organizerId], references: [id])
  promotions  Promotions[]
  reviews     Review[]
  tickets     Ticket[]

  @@map("events")
}

model Ticket {
  id              Int           @id @default(autoincrement())
  ticketLevel     String
  availableTicket Int
  deletedAt       DateTime?
  eventId         Int
  price           Int           @default(0)
  event           Event         @relation(fields: [eventId], references: [id])
  transactions    Transaction[]

  @@map("tickets")
}

model Transaction {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  expiredAt     DateTime?
  paymentProof  String?
  paymentStatus PaymentStatus
  userId        Int
  ticketId      Int
  voucherId     Int?          @unique
  couponId      Int?          @unique
  pointsUsed    Int           @default(0)
  reviews       Review[]
  coupon        Coupon?       @relation(fields: [couponId], references: [id])
  ticket        Ticket        @relation(fields: [ticketId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  voucher       Voucher?      @relation(fields: [voucherId], references: [id])

  @@map("transactions")
}

model Review {
  id            Int         @id @default(autoincrement())
  text          String
  rating        Int
  transactionId Int
  eventId       Int
  reviewerId    Int
  event         Event       @relation(fields: [eventId], references: [id])
  reviewer      User        @relation("Reviewer", fields: [reviewerId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("reviews")
}

model Coupon {
  id          Int          @id @default(autoincrement())
  amount      Int
  expiredDate DateTime
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
  transaction Transaction?

  @@map("coupons")
}

model Point {
  id          Int      @id @default(autoincrement())
  amount      Int
  expiredDate DateTime
  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@map("points")
}

model Voucher {
  id          Int          @id @default(autoincrement())
  amount      Int
  expiredDate DateTime
  userId      Int
  organizerID Int
  transaction Transaction?
  organizer   User         @relation("Organizer", fields: [organizerID], references: [id])
  user        User         @relation("User", fields: [userId], references: [id])

  @@map("vouchers")
}

model Promotions {
  id       Int      @id @default(autoincrement())
  priority Priority
  status   Status
  eventId  Int
  event    Event    @relation(fields: [eventId], references: [id])

  @@map("promotions")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiredAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

enum Role {
  ORGANIZER
  USER
}

enum Priority {
  HIGH
  MID
}

enum Status {
  ACTIVE
  DRAFT
  EXPIRED
}

enum PaymentStatus {
  WAITING_FOR_PAYMENT
  WAITING_FOR_CONFIRM
  PAID
  EXPIRED
  REJECTED
}
