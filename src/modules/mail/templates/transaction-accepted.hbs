<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
  </head>
  <body
    style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f5f5f5;"
  >
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table
            width="500"
            cellpadding="0"
            cellspacing="0"
            style="background-color:#ffffff; margin-top:40px; border-radius:8px; overflow:hidden;"
          >
            <tr>
              <td
                align="center"
                style="background-color:#E6FF06; color:#000000; padding:20px; font-size:20px; font-weight:bold;"
              >
                Transaction Accepted
              </td>
            </tr>

            <tr>
              <td style="padding:30px; color:#333333; font-size:14px;">
                <p>Hi {{username}},</p>

                <p>
                  Your transaction for {{eventName}} has been successfully
                  accepted.
                </p>

                <p>
                  You will receive further details soon. If you have any
                  questions, please contact our support team.
                </p>

                <p>Thank you for choosing us.</p>

                <p>Best regards,<br />Your Team</p>
              </td>
            </tr>

            <tr>
              <td
                align="center"
                style="padding:20px; font-size:12px; color:#888888;"
              >
                © 2026 FRNTROW*. All rights reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
